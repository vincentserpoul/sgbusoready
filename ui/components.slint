// Direction-C custom widgets. All token-driven (see theme.slint), with subtle
// opacity press feedback. No std-widgets — full visual control.

import { Palette, Type } from "theme.slint";

// One bus arrival group on a lane: pre-joined bus label (e.g. "14e·16") and its
// whole-minute countdown, which positions it on the shared scale.
export struct ArrivalTag {
    buses: string,
    minutes: int,
}

// One stop's timeline lane.
export struct StopLane {
    name: string,
    code: string,
    tags: [ArrivalTag],
    // Clock labels for the rolling axis ends: `now` (left) and `now + window`
    // (right), e.g. "09:35" / "10:05". Refreshed on each arrivals poll.
    start-label: string,
    end-label: string,
}

// Content fills the screen width (phone-first); per-screen padding provides the
// margins. Kept as a wrapper so screens can opt into a different layout later.
export component PhoneColumn inherits VerticalLayout {
    @children
}

export component AppBar inherits Rectangle {
    in property <string> title;
    in property <bool> show-back: false;
    in property <string> action-text: "";
    callback back();
    callback action();
    height: 66px;
    HorizontalLayout {
        padding-left: 10px;
        padding-right: 16px;
        spacing: 6px;
        Rectangle {
            width: root.show-back ? 34px : 4px;
            Text {
                text: "←";
                font-size: 22px;
                color: Palette.text;
                visible: root.show-back;
            }
            TouchArea {
                enabled: root.show-back;
                clicked => { root.back(); }
            }
        }
        Text {
            horizontal-stretch: 1;
            text: root.title;
            font-size: Type.heading;
            font-weight: 700;
            color: Palette.text;
            vertical-alignment: center;
        }
        Rectangle {
            width: root.action-text == "" ? 0px : t.preferred-width + 4px;
            t := Text {
                text: root.action-text;
                color: Palette.danger;
                font-size: Type.body;
                font-weight: 600;
                vertical-alignment: center;
            }
            TouchArea {
                enabled: root.action-text != "";
                clicked => { root.action(); }
            }
        }
    }
}

export component PrimaryButton inherits Rectangle {
    in property <string> text;
    in property <bool> enabled: true;
    callback clicked();
    height: 58px;
    border-radius: 14px;
    background: Palette.accent;
    opacity: !root.enabled ? 0.4 : (ta.pressed ? 0.82 : 1.0);
    animate opacity { duration: 100ms; easing: ease-out; }
    Text {
        text: root.text;
        color: Palette.on-accent;
        font-weight: 700;
        font-size: Type.body;
    }
    ta := TouchArea {
        clicked => { if (root.enabled) { root.clicked(); } }
    }
}

export component GhostButton inherits Rectangle {
    in property <string> text;
    callback clicked();
    height: 58px;
    border-radius: 14px;
    background: Palette.surface;
    border-width: 1px;
    border-color: Palette.hairline;
    opacity: ta.pressed ? 0.7 : 1.0;
    animate opacity { duration: 100ms; easing: ease-out; }
    Text {
        text: root.text;
        color: Palette.text-dim;
        font-weight: 600;
        font-size: Type.body;
    }
    ta := TouchArea {
        clicked => { root.clicked(); }
    }
}

export component Chip inherits Rectangle {
    in property <string> text;
    in property <bool> selected;
    callback toggled();
    height: 44px;
    border-radius: 22px;
    background: root.selected ? Palette.accent-solid : Palette.chip-muted-bg;
    opacity: ta.pressed ? 0.78 : 1.0;
    animate opacity { duration: 90ms; easing: ease-out; }
    horizontal-stretch: 0;
    HorizontalLayout {
        padding-left: 13px;
        padding-right: 13px;
        Text {
            vertical-alignment: center;
            text: root.text;
            font-weight: 600;
            font-size: Type.body;
            color: root.selected ? Palette.on-accent : Palette.chip-muted-text;
        }
    }
    ta := TouchArea {
        clicked => { root.toggled(); }
    }
}

export component DayToggle inherits Rectangle {
    in property <string> label;
    in property <bool> on;
    callback toggled();
    width: 46px;
    height: 46px;
    border-radius: 23px;
    background: root.on ? Palette.accent-solid : Palette.chip-muted-bg;
    opacity: ta.pressed ? 0.7 : 1.0;
    animate opacity { duration: 90ms; easing: ease-out; }
    Text {
        text: root.label;
        font-size: Type.label;
        font-weight: 600;
        color: root.on ? Palette.on-accent : Palette.chip-muted-text;
    }
    ta := TouchArea {
        clicked => { root.toggled(); }
    }
}

export component TextField inherits Rectangle {
    in property <string> placeholder;
    in-out property <string> text <=> ti.text;
    callback edited();
    // Drop keyboard focus (e.g. when navigating away from a search screen).
    public function defocus() {
        ti.clear-focus();
    }
    height: 56px;
    border-radius: 12px;
    background: Palette.surface;
    border-width: 1px;
    border-color: ti.has-focus ? Palette.accent-solid : Palette.hairline;
    HorizontalLayout {
        padding-left: 13px;
        padding-right: 13px;
        Rectangle {
            if ti.text == "": Text {
                x: 0;
                vertical-alignment: center;
                horizontal-alignment: left;
                text: root.placeholder;
                color: Palette.text-faint;
                font-size: Type.body;
            }
            ti := TextInput {
                vertical-alignment: center;
                color: Palette.text;
                font-size: Type.body;
                single-line: true;
                edited => { root.edited(); }
            }
        }
    }
}

// A tappable time field: shows HH:MM and emits `picked()` (the app opens the
// native Android time picker, which writes the value back).
export component TimeStepper inherits Rectangle {
    in property <string> caption;
    in property <int> hour;
    in property <int> minute;
    callback picked();
    height: 100px;
    border-radius: 12px;
    background: Palette.surface;
    border-width: 1px;
    border-color: Palette.hairline;
    opacity: ta.pressed ? 0.8 : 1.0;
    animate opacity { duration: 100ms; easing: ease-out; }
    VerticalLayout {
        padding: 10px;
        spacing: 4px;
        Text {
            text: root.caption;
            font-size: Type.label;
            color: Palette.text-faint;
            horizontal-alignment: center;
        }
        Text {
            text: (root.hour < 10 ? "0\{root.hour}" : "\{root.hour}") + ":" + (root.minute < 10 ? "0\{root.minute}" : "\{root.minute}");
            font-size: 38px;
            font-weight: 700;
            color: Palette.text;
            horizontal-alignment: center;
        }
    }
    ta := TouchArea {
        clicked => { root.picked(); }
    }
}

export component FloatingAddButton inherits Rectangle {
    callback clicked();
    width: 66px;
    height: 66px;
    border-radius: 33px;
    background: Palette.accent;
    drop-shadow-blur: 18px;
    drop-shadow-color: #00000077;
    drop-shadow-offset-y: 4px;
    opacity: ta.pressed ? 0.85 : 1.0;
    animate opacity { duration: 100ms; easing: ease-out; }
    Text {
        text: "+";
        font-size: 38px;
        color: Palette.on-accent;
    }
    ta := TouchArea {
        clicked => { root.clicked(); }
    }
}

// A single stop's arrival timeline: bus pills above a baseline, a thin leader to
// each arrival's exact minute, and the red minute below. All tags share one
// scale (`scale-max` minutes across the lane width).
export component TimelineLane inherits Rectangle {
    in property <string> name;
    in property <[ArrivalTag]> tags;
    in property <int> scale-max: 15;
    // Rolling-axis clock labels: `now` (left) and `now + window` (right). Shown
    // small + grey, flanking the timeline at the same level.
    in property <string> start-label;
    in property <string> end-label;
    height: 124px;
    // Geometry is relative to the graph element (the clock labels flank it).
    property <length> pad-l: 4px;
    property <length> usable: graph.width - root.pad-l * 2;
    function cx-of(minutes: int) -> length {
        // `* 1.0` forces a float numerator: an int/int divide would truncate to
        // 0 and stack everything at the left of the lane.
        root.pad-l + root.usable * (minutes * 1.0 / max(root.scale-max, 1))
    }
    VerticalLayout {
        spacing: 2px;
        Text {
            text: root.name;
            font-size: Type.caption;
            font-weight: 600;
            color: Palette.text;
            overflow: elide;
        }
        HorizontalLayout {
            spacing: 8px;
            // Clock labels flank the timeline, dropped to the graduation row so
            // they sit clear of the bus pills (which live in the upper band).
            Text {
                text: root.start-label;
                font-size: Type.label;
                color: Palette.text-faint;
                vertical-alignment: bottom;
            }
            graph := Rectangle {
                horizontal-stretch: 1;
                // Adaptive 5-min graduations spanning the whole window duration;
                // numbered every 5 min for short windows, every 15 for long ones.
                for i in (root.scale-max / 5): Rectangle {
                    property <int> t: (i + 1) * 5;
                    Rectangle {
                        x: root.cx-of(t) - 1px;
                        y: 30px;
                        width: 1px;
                        height: parent.height - 80px;
                        background: Palette.hairline;
                    }
                    if root.scale-max <= 60 || mod(t, 15) == 0: Text {
                        x: root.cx-of(t) - self.width / 2;
                        y: parent.height - 20px;
                        text: "\{t}";
                        font-size: Type.label;
                        color: Palette.text-faint;
                    }
                }
                // baseline (white path)
                Rectangle {
                    x: root.pad-l;
                    y: parent.height - 50px;
                    width: root.usable;
                    height: 2px;
                    background: Palette.text-dim;
                }
                // now marker (neutral)
                Rectangle {
                    x: root.pad-l - 5px;
                    y: parent.height - 54px;
                    width: 11px;
                    height: 11px;
                    border-radius: 6px;
                    background: Palette.text-faint;
                }
                for tag in root.tags: Rectangle {
                    // Clamp position to the fixed range; the label still shows the
                    // real minutes, so a far bus parks at the right edge.
                    property <length> cx: root.cx-of(min(tag.minutes, root.scale-max));
                    // leader (white)
                    Rectangle {
                        x: parent.cx - 1px;
                        y: 30px;
                        width: 2px;
                        height: parent.height - 80px;
                        background: Palette.text-faint;
                    }
                    // red dot on the line, under the bus pill
                    Rectangle {
                        x: parent.cx - 6px;
                        y: parent.height - 55px;
                        width: 12px;
                        height: 12px;
                        border-radius: 6px;
                        background: Palette.accent-solid;
                    }
                    // bus pill above the line — width hugs its label so each tag
                    // reads as a separate chip (no width => fills the lane).
                    pill := Rectangle {
                        x: parent.cx - self.width / 2;
                        y: 0px;
                        width: plabel.preferred-width + 18px;
                        height: 30px;
                        border-radius: 10px;
                        background: Palette.accent-solid;
                        plabel := Text {
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            text: tag.buses;
                            font-size: Type.body;
                            font-weight: 700;
                            color: Palette.on-accent;
                        }
                    }
                    // red arrival timing just below the line, suffixed "m"
                    Text {
                        x: parent.cx - self.width / 2;
                        y: parent.height - 44px;
                        text: tag.minutes <= 0 ? "due" : "\{tag.minutes}m";
                        font-size: Type.body;
                        font-weight: 700;
                        color: Palette.accent-solid;
                    }
                }
            }
            Text {
                text: root.end-label;
                font-size: Type.label;
                color: Palette.text-faint;
                vertical-alignment: bottom;
            }
        }
    }
}

// An editor card for one stop: name/code, a remove control, and the stop's
// services as toggle-chips (selected = tracked).
export component StopEditorCard inherits Rectangle {
    in property <string> name;
    in property <string> code;
    in property <[string]> services;
    in property <[bool]> selected;
    callback remove();
    callback toggle(int);
    border-radius: 12px;
    background: Palette.surface;
    border-width: 1px;
    border-color: Palette.hairline;
    VerticalLayout {
        padding: 12px;
        spacing: 8px;
        HorizontalLayout {
            spacing: 6px;
            VerticalLayout {
                horizontal-stretch: 1;
                spacing: 1px;
                Text {
                    text: root.name == "" ? root.code : root.name;
                    font-weight: 700;
                    font-size: Type.body;
                    color: Palette.text;
                    overflow: elide;
                }
                Text {
                    text: root.code;
                    font-size: Type.label;
                    color: Palette.text-dim;
                }
            }
            Rectangle {
                width: 34px;
                height: 34px;
                border-radius: 17px;
                background: rmv.pressed ? Palette.accent-solid : Palette.chip-muted-bg;
                animate background { duration: 90ms; easing: ease-out; }
                Text {
                    text: "×";
                    font-size: 24px;
                    font-weight: 700;
                    color: rmv.pressed ? Palette.on-accent : Palette.text-dim;
                }
                rmv := TouchArea { clicked => { root.remove(); } }
            }
        }
        Flickable {
            height: 46px;
            viewport-width: row.preferred-width;
            viewport-height: self.height;
            row := HorizontalLayout {
                spacing: 8px;
                for svc[i] in root.services: Chip {
                    text: svc;
                    selected: root.selected[i];
                    toggled => { root.toggle(i); }
                }
                if root.services.length == 0: Text {
                    text: "No services found";
                    color: Palette.text-faint;
                    vertical-alignment: center;
                    font-size: Type.body;
                }
            }
        }
    }
}

export component StopResultRow inherits Rectangle {
    in property <string> name;
    in property <string> sub;
    callback clicked();
    height: 70px;
    background: ta.pressed ? Palette.surface : transparent;
    border-radius: 12px;
    animate background { duration: 80ms; }
    VerticalLayout {
        padding-left: 8px;
        padding-right: 8px;
        spacing: 2px;
        alignment: center;
        Text { text: root.name; font-size: Type.body; font-weight: 600; color: Palette.text; overflow: elide; }
        Text { text: root.sub; font-size: Type.label; color: Palette.text-dim; overflow: elide; }
    }
    ta := TouchArea {
        clicked => { root.clicked(); }
    }
}
