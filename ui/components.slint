// Direction-C custom widgets. All token-driven (see theme.slint), with subtle
// opacity press feedback. No std-widgets — full visual control.

import { Palette, Type } from "theme.slint";

// One bus arrival group on a lane: pre-joined bus label (e.g. "14e·16") and its
// whole-minute countdown, which positions it on the shared scale.
export struct ArrivalTag {
    buses: string,
    minutes: int,
}

// One stop's timeline lane.
export struct StopLane {
    name: string,
    code: string,
    tags: [ArrivalTag],
}

// Content fills the screen width (phone-first); per-screen padding provides the
// margins. Kept as a wrapper so screens can opt into a different layout later.
export component PhoneColumn inherits VerticalLayout {
    @children
}

export component AppBar inherits Rectangle {
    in property <string> title;
    in property <bool> show-back: false;
    in property <string> action-text: "";
    callback back();
    callback action();
    height: 66px;
    HorizontalLayout {
        padding-left: 10px;
        padding-right: 16px;
        spacing: 6px;
        Rectangle {
            width: root.show-back ? 34px : 4px;
            Text {
                text: "←";
                font-size: 22px;
                color: Palette.text;
                visible: root.show-back;
            }
            TouchArea {
                enabled: root.show-back;
                clicked => { root.back(); }
            }
        }
        Text {
            horizontal-stretch: 1;
            text: root.title;
            font-size: Type.heading;
            font-weight: 700;
            color: Palette.text;
            vertical-alignment: center;
        }
        Rectangle {
            width: root.action-text == "" ? 0px : t.preferred-width + 4px;
            t := Text {
                text: root.action-text;
                color: Palette.danger;
                font-size: Type.body;
                font-weight: 600;
                vertical-alignment: center;
            }
            TouchArea {
                enabled: root.action-text != "";
                clicked => { root.action(); }
            }
        }
    }
}

export component PrimaryButton inherits Rectangle {
    in property <string> text;
    in property <bool> enabled: true;
    callback clicked();
    height: 58px;
    border-radius: 14px;
    background: Palette.accent;
    opacity: !root.enabled ? 0.4 : (ta.pressed ? 0.82 : 1.0);
    animate opacity { duration: 100ms; easing: ease-out; }
    Text {
        text: root.text;
        color: Palette.on-accent;
        font-weight: 700;
        font-size: Type.body;
    }
    ta := TouchArea {
        clicked => { if (root.enabled) { root.clicked(); } }
    }
}

export component GhostButton inherits Rectangle {
    in property <string> text;
    callback clicked();
    height: 58px;
    border-radius: 14px;
    background: Palette.surface;
    border-width: 1px;
    border-color: Palette.hairline;
    opacity: ta.pressed ? 0.7 : 1.0;
    animate opacity { duration: 100ms; easing: ease-out; }
    Text {
        text: root.text;
        color: Palette.text-dim;
        font-weight: 600;
        font-size: Type.body;
    }
    ta := TouchArea {
        clicked => { root.clicked(); }
    }
}

export component Chip inherits Rectangle {
    in property <string> text;
    in property <bool> selected;
    callback toggled();
    height: 44px;
    border-radius: 22px;
    background: root.selected ? Palette.accent-solid : Palette.chip-muted-bg;
    opacity: ta.pressed ? 0.78 : 1.0;
    animate opacity { duration: 90ms; easing: ease-out; }
    horizontal-stretch: 0;
    HorizontalLayout {
        padding-left: 13px;
        padding-right: 13px;
        Text {
            vertical-alignment: center;
            text: root.text;
            font-weight: 600;
            font-size: Type.body;
            color: root.selected ? Palette.on-accent : Palette.chip-muted-text;
        }
    }
    ta := TouchArea {
        clicked => { root.toggled(); }
    }
}

export component DayToggle inherits Rectangle {
    in property <string> label;
    in property <bool> on;
    callback toggled();
    width: 46px;
    height: 46px;
    border-radius: 23px;
    background: root.on ? Palette.accent-solid : Palette.chip-muted-bg;
    opacity: ta.pressed ? 0.7 : 1.0;
    animate opacity { duration: 90ms; easing: ease-out; }
    Text {
        text: root.label;
        font-size: Type.label;
        font-weight: 600;
        color: root.on ? Palette.on-accent : Palette.chip-muted-text;
    }
    ta := TouchArea {
        clicked => { root.toggled(); }
    }
}

export component TextField inherits Rectangle {
    in property <string> placeholder;
    in-out property <string> text <=> ti.text;
    callback edited();
    // Drop keyboard focus (e.g. when navigating away from a search screen).
    public function defocus() {
        ti.clear-focus();
    }
    height: 56px;
    border-radius: 12px;
    background: Palette.surface;
    border-width: 1px;
    border-color: ti.has-focus ? Palette.accent-solid : Palette.hairline;
    HorizontalLayout {
        padding-left: 13px;
        padding-right: 13px;
        Rectangle {
            if ti.text == "": Text {
                x: 0;
                vertical-alignment: center;
                horizontal-alignment: left;
                text: root.placeholder;
                color: Palette.text-faint;
                font-size: Type.body;
            }
            ti := TextInput {
                vertical-alignment: center;
                color: Palette.text;
                font-size: Type.body;
                single-line: true;
                edited => { root.edited(); }
            }
        }
    }
}

// A tappable time field: shows HH:MM and emits `picked()` (the app opens the
// native Android time picker, which writes the value back).
export component TimeStepper inherits Rectangle {
    in property <string> caption;
    in property <int> hour;
    in property <int> minute;
    callback picked();
    height: 100px;
    border-radius: 12px;
    background: Palette.surface;
    border-width: 1px;
    border-color: Palette.hairline;
    opacity: ta.pressed ? 0.8 : 1.0;
    animate opacity { duration: 100ms; easing: ease-out; }
    VerticalLayout {
        padding: 10px;
        spacing: 4px;
        Text {
            text: root.caption;
            font-size: Type.label;
            color: Palette.text-faint;
            horizontal-alignment: center;
        }
        Text {
            text: (root.hour < 10 ? "0\{root.hour}" : "\{root.hour}") + ":" + (root.minute < 10 ? "0\{root.minute}" : "\{root.minute}");
            font-size: 38px;
            font-weight: 700;
            color: Palette.text;
            horizontal-alignment: center;
        }
    }
    ta := TouchArea {
        clicked => { root.picked(); }
    }
}

export component FloatingAddButton inherits Rectangle {
    callback clicked();
    width: 66px;
    height: 66px;
    border-radius: 33px;
    background: Palette.accent;
    drop-shadow-blur: 18px;
    drop-shadow-color: #00000077;
    drop-shadow-offset-y: 4px;
    opacity: ta.pressed ? 0.85 : 1.0;
    animate opacity { duration: 100ms; easing: ease-out; }
    Text {
        text: "+";
        font-size: 38px;
        color: Palette.on-accent;
    }
    ta := TouchArea {
        clicked => { root.clicked(); }
    }
}

export component CommuteCard inherits Rectangle {
    in property <string> label;
    in property <string> status;
    in property <bool> active;
    callback clicked();
    height: 112px;
    border-radius: 18px;
    background: root.active ? Palette.hero : Palette.surface;
    border-width: 1px;
    border-color: root.active ? #3A1E1E : Palette.hairline;
    opacity: ta.pressed ? 0.9 : 1.0;
    animate opacity { duration: 100ms; easing: ease-out; }
    VerticalLayout {
        padding: 14px;
        spacing: 5px;
        HorizontalLayout {
            Text {
                horizontal-stretch: 1;
                text: root.label;
                font-size: Type.body;
                font-weight: 700;
                color: Palette.text;
                overflow: elide;
            }
            if root.active: Rectangle {
                background: Palette.accent-solid;
                border-radius: 11px;
                HorizontalLayout {
                    padding-left: 9px;
                    padding-right: 9px;
                    Text { vertical-alignment: center; text: "active now"; font-size: Type.label; font-weight: 600; color: Palette.on-accent; }
                }
            }
        }
        Text {
            text: root.status;
            font-size: Type.caption;
            color: Palette.text-dim;
            overflow: elide;
        }
    }
    ta := TouchArea {
        clicked => { root.clicked(); }
    }
}

// A single stop's arrival timeline: bus pills above a baseline, a thin leader to
// each arrival's exact minute, and the red minute below. All tags share one
// scale (`scale-max` minutes across the lane width).
export component TimelineLane inherits Rectangle {
    in property <string> name;
    in property <[ArrivalTag]> tags;
    in property <int> scale-max: 15;
    height: 74px;
    property <length> pad-l: 6px;
    property <length> usable: self.width - root.pad-l - 12px;
    VerticalLayout {
        spacing: 2px;
        Text {
            text: root.name;
            font-size: Type.label;
            color: Palette.text-dim;
            overflow: elide;
        }
        Rectangle {
            vertical-stretch: 1;
            // baseline
            Rectangle {
                x: root.pad-l;
                y: parent.height - 22px;
                width: root.usable;
                height: 2px;
                background: Palette.hairline;
            }
            // now dot
            Rectangle {
                x: root.pad-l - 4px;
                y: parent.height - 26px;
                width: 9px;
                height: 9px;
                border-radius: 5px;
                background: Palette.accent-solid;
            }
            for tag in root.tags: Rectangle {
                property <length> cx: root.pad-l + root.usable * (tag.minutes / max(root.scale-max, 1));
                // leader
                Rectangle {
                    x: parent.cx - 1px;
                    y: 22px;
                    width: 2px;
                    height: parent.height - 44px;
                    background: Palette.hairline;
                }
                // bus pill above the line
                pill := Rectangle {
                    x: parent.cx - self.width / 2;
                    y: 2px;
                    height: 22px;
                    border-radius: 8px;
                    background: Palette.accent-solid;
                    HorizontalLayout {
                        padding-left: 7px;
                        padding-right: 7px;
                        Text {
                            vertical-alignment: center;
                            text: tag.buses;
                            font-size: Type.label;
                            font-weight: 700;
                            color: Palette.on-accent;
                        }
                    }
                }
                // red minute below the line
                Text {
                    x: parent.cx - self.width / 2;
                    y: parent.height - 18px;
                    text: tag.minutes <= 0 ? "due" : "\{tag.minutes}";
                    font-size: Type.label;
                    font-weight: 700;
                    color: Palette.accent-solid;
                }
            }
        }
    }
}

// An editor card for one stop: name/code, a remove control, and the stop's
// services as toggle-chips (selected = tracked).
export component StopEditorCard inherits Rectangle {
    in property <string> name;
    in property <string> code;
    in property <[string]> services;
    in property <[bool]> selected;
    callback remove();
    callback toggle(int);
    border-radius: 12px;
    background: Palette.surface;
    border-width: 1px;
    border-color: Palette.hairline;
    VerticalLayout {
        padding: 12px;
        spacing: 8px;
        HorizontalLayout {
            spacing: 6px;
            VerticalLayout {
                horizontal-stretch: 1;
                spacing: 1px;
                Text {
                    text: root.name == "" ? root.code : root.name;
                    font-weight: 700;
                    font-size: Type.body;
                    color: Palette.text;
                    overflow: elide;
                }
                Text {
                    text: root.code;
                    font-size: Type.label;
                    color: Palette.text-dim;
                }
            }
            Rectangle {
                width: 32px;
                Text { text: "✕"; font-size: 18px; color: Palette.text-dim; }
                TouchArea { clicked => { root.remove(); } }
            }
        }
        Flickable {
            height: 46px;
            viewport-width: row.preferred-width;
            viewport-height: self.height;
            row := HorizontalLayout {
                spacing: 8px;
                for svc[i] in root.services: Chip {
                    text: svc;
                    selected: root.selected[i];
                    toggled => { root.toggle(i); }
                }
                if root.services.length == 0: Text {
                    text: "No services found";
                    color: Palette.text-faint;
                    vertical-alignment: center;
                    font-size: Type.body;
                }
            }
        }
    }
}

export component StopResultRow inherits Rectangle {
    in property <string> name;
    in property <string> sub;
    callback clicked();
    height: 70px;
    background: ta.pressed ? Palette.surface : transparent;
    border-radius: 12px;
    animate background { duration: 80ms; }
    VerticalLayout {
        padding-left: 8px;
        padding-right: 8px;
        spacing: 2px;
        alignment: center;
        Text { text: root.name; font-size: Type.body; font-weight: 600; color: Palette.text; overflow: elide; }
        Text { text: root.sub; font-size: Type.label; color: Palette.text-dim; overflow: elide; }
    }
    ta := TouchArea {
        clicked => { root.clicked(); }
    }
}
