// Design tokens — "SMRT" vibe: dark, clean, with a confident Singapore-transit
// red accent (replacing the previous indigo→coral gradient). Every component
// reads from here, so re-theming (or a light mode) is a token swap.

export global Palette {
    out property <color> bg: #0A0B0E;
    out property <color> surface: #15171C;
    out property <color> surface-alt: #1C1F26;
    out property <color> hairline: #262A31;
    out property <color> text: #F2F3F5;
    out property <color> text-dim: #A8AEB8;
    out property <color> text-faint: #6B7178;
    out property <color> accent-solid: #E2231A;
    out property <color> accent-warm: #FF6A5F;
    out property <color> on-accent: #FFFFFF;
    out property <color> chip-muted-bg: #FFFFFF12;
    out property <color> chip-muted-text: #C8CCD2;
    out property <color> danger: #FF6A5F;
    // Subtle single-hue red gradient (depth without the "colorful" look).
    out property <brush> accent: @linear-gradient(180deg, #E5271E 0%, #C4160F 100%);
    // Active commute card: a quiet dark-red wash.
    out property <brush> hero: @linear-gradient(135deg, #241316 0%, #1A0E10 100%);
}

export global Type {
    out property <length> title: 34px;
    out property <length> heading: 23px;
    out property <length> body: 20px;
    out property <length> label: 15px;
    out property <length> caption: 17px;
}
