import { Palette, Type } from "theme.slint";
import {
    PhoneColumn, AppBar, PrimaryButton, GhostButton, Chip, DayToggle, TextField, TimeStepper,
    FloatingAddButton, StopResultRow, TimelineLane, StopEditorCard, ArrivalTag, StopLane,
} from "components.slint";
import { ScrollView } from "std-widgets.slint";

struct CommuteRow {
    label: string,
    active: bool,
    index: int,
    lanes: [StopLane],
    scale-max: int,
    // Inactive-card data:
    days: [bool],      // length 7, Mon..Sun
    today: int,        // 0..6 (Mon..Sun) for highlight; -1 if N/A
    next-time: string, // "next Mon 18:00"
    counts: string,    // "2 stops · 4 buses"
}

struct EditStop {
    code: string,
    name: string,
    services: [string],
    selected: [bool],
}

struct StopResult {
    code: string,
    name: string,
    road: string,
}

enum Screen { list, editor, search }

export component AppWindow inherits Window {
    in property <[CommuteRow]> rows;
    in-out property <Screen> screen: Screen.list;
    // Top status-bar inset (the app draws edge-to-edge on Android).
    in property <length> top-inset: 0px;

    // Hero status banner (relative status, refreshed each poll). No absolute
    // clock — that would duplicate and drift from the OS status-bar clock.
    in property <string> hero-status;
    // Weekday pill letters (Mon..Sun) for inactive commute cards.
    property <[string]> day-letters: ["M", "T", "W", "T", "F", "S", "S"];

    // Editor form state.
    in-out property <int> editing-index: -1;
    in-out property <string> form-label;
    in property <[EditStop]> form-stops;
    in-out property <bool> day-mon;
    in-out property <bool> day-tue;
    in-out property <bool> day-wed;
    in-out property <bool> day-thu;
    in-out property <bool> day-fri;
    in-out property <bool> day-sat;
    in-out property <bool> day-sun;
    in-out property <int> start-hour: 8;
    in-out property <int> start-minute: 0;
    in-out property <int> end-hour: 9;
    in-out property <int> end-minute: 0;
    in-out property <string> error-text;

    // Stop-search state.
    in-out property <string> search-query;
    in property <[StopResult]> search-results;
    in property <bool> catalog-loading;

    callback save();
    callback delete(int);
    callback edit(int);
    callback new-commute();
    callback search-changed();
    callback stop-picked(string);
    callback toggle-bus(int, int);
    callback remove-stop(int);
    callback pick-time(string);
    callback screen-changed(bool);

    // Keep the native side informed which screen is showing (for Back handling).
    changed screen => {
        root.screen-changed(self.screen == Screen.list);
    }

    title: "SG Bus Commute";
    background: Palette.bg;
    preferred-width: 400px;
    preferred-height: 780px;

    // ---- List screen ----
    Rectangle {
        visible: root.screen == Screen.list;
        PhoneColumn {
        VerticalLayout {
            padding-left: 16px;
            padding-right: 16px;
            padding-bottom: 16px;
            padding-top: root.top-inset + 16px;
            spacing: 12px;
            Text {
                text: "Commutes";
                font-size: Type.title;
                font-weight: 800;
                color: Palette.text;
            }
            // At-a-glance status banner (relative — Live now / Next … / idle).
            Rectangle {
                border-radius: 14px;
                background: @linear-gradient(135deg, Palette.surface, Palette.bg);
                border-width: 1px;
                border-color: Palette.hairline;
                drop-shadow-color: #00000033;
                drop-shadow-blur: 12px;
                drop-shadow-offset-y: 3px;
                HorizontalLayout {
                    padding: 14px;
                    Text {
                        text: root.hero-status;
                        font-size: Type.body;
                        font-weight: 600;
                        color: Palette.text;
                        overflow: elide;
                    }
                    Rectangle { horizontal-stretch: 1; }
                }
            }
            ScrollView {
                vertical-stretch: 1;
                VerticalLayout {
                    spacing: 10px;
                    alignment: start;
                    for row in root.rows: Rectangle {
                        border-radius: 18px;
                        background: Palette.surface;
                        border-width: 1px;
                        border-color: row.active ? Palette.text-faint : Palette.hairline;
                        drop-shadow-color: #00000033;
                        drop-shadow-blur: 10px;
                        drop-shadow-offset-y: 3px;
                        VerticalLayout {
                            padding: 14px;
                            spacing: 8px;
                            HorizontalLayout {
                                spacing: 6px;
                                Text {
                                    horizontal-stretch: 1;
                                    text: row.label;
                                    font-size: Type.body;
                                    font-weight: 700;
                                    color: Palette.text;
                                    overflow: elide;
                                }
                                if row.active: Rectangle {
                                    background: Palette.accent-solid;
                                    border-radius: 11px;
                                    HorizontalLayout {
                                        padding-left: 9px;
                                        padding-right: 9px;
                                        Text { vertical-alignment: center; text: "live"; font-size: Type.label; font-weight: 600; color: Palette.on-accent; }
                                    }
                                }
                                if !row.active: Text { text: "›"; font-size: 20px; color: Palette.text-dim; }
                            }
                            if !row.active: VerticalLayout {
                                spacing: 10px;
                                // Weekday pills — tracked days filled, today emphasised.
                                HorizontalLayout {
                                    spacing: 6px;
                                    for d[i] in row.days: Rectangle {
                                        width: 28px;
                                        height: 28px;
                                        border-radius: 14px;
                                        background: d ? Palette.accent-solid : Palette.bg;
                                        border-width: i == row.today ? 2px : 1px;
                                        border-color: i == row.today ? Palette.text : Palette.hairline;
                                        Text {
                                            width: 100%;
                                            height: 100%;
                                            text: root.day-letters[i];
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                            font-size: Type.label;
                                            font-weight: 600;
                                            color: d ? Palette.on-accent : Palette.text-dim;
                                        }
                                    }
                                    Rectangle { horizontal-stretch: 1; }
                                }
                                HorizontalLayout {
                                    Text {
                                        text: row.next-time;
                                        font-size: Type.caption;
                                        color: Palette.text-dim;
                                    }
                                    Rectangle { horizontal-stretch: 1; }
                                    Text {
                                        text: row.counts;
                                        font-size: Type.caption;
                                        color: Palette.text-faint;
                                    }
                                }
                            }
                            if row.active: VerticalLayout {
                                spacing: 6px;
                                for lane in row.lanes: TimelineLane {
                                    name: lane.name;
                                    tags: lane.tags;
                                    scale-max: row.scale-max;
                                    start-label: lane.start-label;
                                    end-label: lane.end-label;
                                }
                            }
                        }
                        TouchArea {
                            clicked => {
                                root.edit(row.index);
                                root.screen = Screen.editor;
                            }
                        }
                    }
                    if root.rows.length == 0: VerticalLayout {
                        padding-top: 48px;
                        spacing: 14px;
                        // Centered bus glyph.
                        HorizontalLayout {
                            Rectangle { horizontal-stretch: 1; }
                            Rectangle {
                                width: 72px;
                                height: 56px;
                                Rectangle {
                                    y: 0px;
                                    width: 72px;
                                    height: 44px;
                                    border-radius: 12px;
                                    background: Palette.surface;
                                    border-width: 2px;
                                    border-color: Palette.accent-solid;
                                    Rectangle { x: 9px; y: 10px; width: 14px; height: 14px; border-radius: 3px; background: Palette.accent-solid; }
                                    Rectangle { x: 29px; y: 10px; width: 14px; height: 14px; border-radius: 3px; background: Palette.accent-solid; }
                                    Rectangle { x: 49px; y: 10px; width: 14px; height: 14px; border-radius: 3px; background: Palette.accent-solid; }
                                }
                                Rectangle { x: 16px; y: 42px; width: 12px; height: 12px; border-radius: 6px; background: Palette.text-dim; }
                                Rectangle { x: 44px; y: 42px; width: 12px; height: 12px; border-radius: 6px; background: Palette.text-dim; }
                            }
                            Rectangle { horizontal-stretch: 1; }
                        }
                        Text {
                            text: "No commutes yet";
                            font-size: Type.body;
                            font-weight: 700;
                            color: Palette.text;
                            horizontal-alignment: center;
                        }
                        Text {
                            text: "Tap + to track your first bus";
                            font-size: Type.caption;
                            color: Palette.text-faint;
                            horizontal-alignment: center;
                        }
                    }
                }
            }
        }
        }
        FloatingAddButton {
            x: parent.width - self.width - 20px;
            y: parent.height - self.height - 36px;
            clicked => {
                root.new-commute();
                root.screen = Screen.editor;
            }
        }
    }

    // ---- Editor screen ----
    Rectangle {
        visible: root.screen == Screen.editor;
        PhoneColumn {
        VerticalLayout {
            padding-top: root.top-inset;
            AppBar {
                title: root.editing-index < 0 ? "New commute" : "Edit commute";
                show-back: true;
                action-text: root.editing-index < 0 ? "" : "Delete";
                back => { root.screen = Screen.list; }
                action => {
                    root.delete(root.editing-index);
                    root.screen = Screen.list;
                }
            }
            ScrollView {
                VerticalLayout {
                    padding: 16px;
                    spacing: 8px;
                    alignment: start;

                    Text { text: "Label"; font-size: Type.label; color: Palette.text-faint; }
                    TextField {
                        placeholder: "Label (optional)";
                        text <=> root.form-label;
                    }

                    Text { text: "Active days"; font-size: Type.label; color: Palette.text-faint; }
                    HorizontalLayout {
                        spacing: 6px;
                        DayToggle { label: "M"; on: root.day-mon; toggled => { root.day-mon = !root.day-mon; } }
                        DayToggle { label: "T"; on: root.day-tue; toggled => { root.day-tue = !root.day-tue; } }
                        DayToggle { label: "W"; on: root.day-wed; toggled => { root.day-wed = !root.day-wed; } }
                        DayToggle { label: "T"; on: root.day-thu; toggled => { root.day-thu = !root.day-thu; } }
                        DayToggle { label: "F"; on: root.day-fri; toggled => { root.day-fri = !root.day-fri; } }
                        DayToggle { label: "S"; on: root.day-sat; toggled => { root.day-sat = !root.day-sat; } }
                        DayToggle { label: "S"; on: root.day-sun; toggled => { root.day-sun = !root.day-sun; } }
                    }

                    Text { text: "Window"; font-size: Type.label; color: Palette.text-faint; }
                    HorizontalLayout {
                        spacing: 10px;
                        TimeStepper {
                            caption: "Start";
                            hour: root.start-hour;
                            minute: root.start-minute;
                            picked => { root.pick-time("start"); }
                        }
                        TimeStepper {
                            caption: "End";
                            hour: root.end-hour;
                            minute: root.end-minute;
                            picked => { root.pick-time("end"); }
                        }
                    }

                    Text { text: "Stops & buses"; font-size: Type.label; color: Palette.text-faint; }
                    for st[si] in root.form-stops: StopEditorCard {
                        name: st.name;
                        code: st.code;
                        services: st.services;
                        selected: st.selected;
                        remove => { root.remove-stop(si); }
                        toggle(bi) => { root.toggle-bus(si, bi); }
                    }
                    GhostButton {
                        text: "+ Add stop";
                        clicked => {
                            root.search-query = "";
                            root.screen = Screen.search;
                        }
                    }

                    if root.error-text != "": Text {
                        text: root.error-text;
                        color: Palette.danger;
                        font-size: Type.caption;
                        wrap: word-wrap;
                    }

                    Rectangle { height: 6px; }
                    PrimaryButton {
                        text: "Save commute";
                        clicked => { root.save(); }
                    }
                }
            }
        }
        }
    }

    // ---- Stop-search screen ----
    Rectangle {
        visible: root.screen == Screen.search;
        PhoneColumn {
        VerticalLayout {
            padding-top: root.top-inset;
            AppBar {
                title: "Choose stop";
                show-back: true;
                back => {
                    sf.defocus();
                    root.screen = Screen.editor;
                }
            }
            VerticalLayout {
                padding: 16px;
                spacing: 10px;
                sf := TextField {
                    placeholder: "Search name or code";
                    text <=> root.search-query;
                    edited => { root.search-changed(); }
                }
                if root.catalog-loading: Text {
                    text: "Updating bus stops…";
                    color: Palette.text-faint;
                    font-size: Type.body;
                }
                ScrollView {
                    vertical-stretch: 1;
                    VerticalLayout {
                        spacing: 2px;
                        alignment: start;
                        for r in root.search-results: StopResultRow {
                            name: r.name;
                            sub: r.road + " · " + r.code;
                            clicked => {
                                sf.defocus();
                                root.stop-picked(r.code);
                            }
                        }
                    }
                }
            }
        }
        }
    }
}
